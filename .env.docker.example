# Copy this file to .env before running docker compose on the server.

# Public port exposed by the Nginx reverse proxy.
HTTP_PORT=80

# Required for production: set a fixed private value.
# If empty, a new token is generated on every container start.
ADMIN_TOKEN=change-this-admin-token

# Optional for same-origin Nginx deployment.
# Set these only if you want the backend log to print the exact public admin URL,
# or if the frontend and API are served from different origins.
# ADMIN_UI_BASE_URL=http://YOUR_SERVER_IP
# CORS_ORIGINS=http://YOUR_SERVER_IP

TEAM_ANNOTATION_GOAL=50
TEAM_MEMBER_LIMIT=5
SESSION_DURATION_HOURS=24
SUBMISSION_CHALLENGE_TTL_MINUTES=10
SUBMISSION_COOLDOWN_MINUTES=5
SUBMISSION_TEAM_MAX_ATTEMPTS=10
DEFAULT_TEST_DATASET_SOURCE=local_test
