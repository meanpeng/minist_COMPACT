APP_NAME=mnist-compact-api
DATABASE_PATH=./data/app.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Set this to your public frontend origin when deploying, for example https://app.example.com
ADMIN_UI_BASE_URL=http://localhost:5173
# Optional: set a fixed admin token instead of generating one on startup.
ADMIN_TOKEN=
TEAM_ANNOTATION_GOAL=50
TEAM_MEMBER_LIMIT=5
SESSION_DURATION_HOURS=24
SUBMISSION_CHALLENGE_TTL_MINUTES=10
SUBMISSION_COOLDOWN_MINUTES=5
SUBMISSION_TEAM_MAX_ATTEMPTS=10
